# === Django / Backend ===
# Genera una nueva clave secreta para producción
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=0.0.0.0,localhost,127.0.0.1

# === Herramientas Externas ===
# Ruta al ejecutable de 7-Zip o WinRAR para extracción de archivos .rar
UNRAR_TOOL_PATH=C:/Program Files/7-Zip/7z.exe

# === PaaSify Configuration ===
# URL base de la aplicación (ej: http://paasify.example.com)
# Si se deja vacío, se intentará detectar automáticamente
PAASIFY_BASE_URL=

# === Configuración Base de Datos (PostgreSQL) ===
# Si DB_NAME está vacío, se usará SQLite por defecto (db.sqlite3)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# === Docker Hub Authentication (Opcional) ===
# Credenciales para autenticación con Docker Hub
# Aumenta el límite de pulls de 100 a 200 por cada 6 horas
# Deja vacío para usar Docker sin autenticación
DOCKER_HUB_USERNAME=
DOCKER_HUB_PASSWORD=
